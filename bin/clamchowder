#!/bin/zsh

# -----------------------------------------------------------------------------
# ClamChowder - Standarized Operational Command Framework
# -----------------------------------------------------------------------------

# Base paths
readonly CLAM_ROOT=${0:A:h:h}
readonly CLAM_LIB="${CLAM_ROOT}/lib"
readonly CLAM_SKELETON="${CLAM_ROOT}/skeleton"
readonly CLAM_MO="${CLAM_LIB}/mo/mo"

# User-specific commands directory (default to $CLAM_ROOT/commands)
# Can be overridden by environment variable
export CLAM_COMMANDS_DIR="${CLAM_COMMANDS_DIR:-${CLAM_ROOT}/commands}"

# Load libraries
source "${CLAM_LIB}/ui.zsh"
source "${CLAM_LIB}/core.zsh"

function usage() {
    echo "ClamChowder🥣🐚 - Standardized Operational Command Framework"
    echo ""
    echo "Usage: clamchowder <subcommand> [args]"
    echo ""
    echo "Subcommands:"
    echo "  cook <name>         Scaffold a new operational command project"
    echo "  link <name> [alias] Register command to /usr/local/bin (requires sudo)"
    echo "  list                List all managed commands"
    echo "  taste <name>        Preview the command's documentation"
    echo "  serve <name> [args] Run the command through the framework"
    echo "  help                Show this help message"
}

# --- Subcommand Implementations ---

function sub_cook() {
    local name=$1
    if [[ -z "$name" ]]; then
        clam_error "Missing command name. Usage: clamchowder cook <name>"
        return 1
    fi

    # Check for name collisions
    if whence "$name" > /dev/null; then
        local existing_path=$(whence -p "$name")
        clam_error "Command '$name' already exists in your system!"
        [[ -n "$existing_path" ]] && echo "Located at: $existing_path"
        echo "Please choose a different name to avoid conflicts."
        return 1
    fi

    local target_dir="${CLAM_COMMANDS_DIR}/${name}"
    if [[ -d "$target_dir" ]]; then
        clam_error "Command '$name' already exists at $target_dir"
        return 1
    fi

    clam_info "Cooking new command: $name..."
    mkdir -p "${target_dir}"/{bin,config,doc}

    # Standard Skeleton Rendering
    sed -e "s|{{name}}|${name}|g" \
        -e "s|{{CLAM_MO}}|${CLAM_MO}|g" \
        "${CLAM_SKELETON}/bin/main.zsh" > "${target_dir}/bin/main"
    
    sed "s|{{name}}|${name}|g" "${CLAM_SKELETON}/config/main.zsh" > "${target_dir}/config/main.zsh"
    sed "s|{{name}}|${name}|g" "${CLAM_SKELETON}/doc/explanation.mo" > "${target_dir}/doc/explanation.mo"
    
    chmod +x "${target_dir}/bin/main"

    # --- Interactive SQL Setup ---
    echo -n "🥣 Add SQL features to this command? [y/N]: "
    read -r add_sql
    if [[ "$add_sql" =~ ^[yY]$ ]]; then
        mkdir -p "${target_dir}/sql"
        sed "s|{{name}}|${name}|g" "${CLAM_SKELETON}/sql/query.sql" > "${target_dir}/sql/query.sql"
        
        echo -n "   Enter DB_HOST [localhost]: "
        read -r db_host
        db_host=${db_host:-localhost}
        
        echo -n "   Enter DB_USER [root]: "
        read -r db_user
        db_user=${db_user:-root}

        echo -n "   Enter DB_NAME: "
        read -r db_name

        {
            echo ""
            echo "# --- SQL Configuration (Added by cook) ---"
            echo "export DB_HOST=\"$db_host\""
            echo "export DB_USER=\"$db_user\""
            echo "export DB_NAME=\"$db_name\""
        } >> "${target_dir}/config/main.zsh"
        
        clam_success "SQL features added and config updated."
    fi

    clam_success "Successfully cooked '$name' at $target_dir"
    echo "Next step: clamchowder link $name"
}

function sub_link() {
    local name=$1
    local alias=$2
    
    if [[ -z "$name" ]]; then
        clam_error "Missing command name. Usage: clamchowder link <name> [alias]"
        return 1
    fi

    # Default alias to the project name if not provided
    [[ -z "$alias" ]] && alias="$name"

    if ! is_valid_command "$name"; then
        clam_error "Command '$name' not found."
        return 1
    fi

    local src="${CLAM_COMMANDS_DIR}/${name}/bin/main"
    local dest="/usr/local/bin/${alias}"

    # Double check if we are about to overwrite a critical system command
    if [[ -e "$dest" ]]; then
        if [[ ! -L "$dest" ]]; then
            clam_error "Collision detected! '$dest' is a real file/binary, not a symbolic link."
            clam_error "Aborting to prevent damaging system commands."
            return 1
        fi
        clam_warn "$dest already exists as a symlink. Overwriting..."
        sudo rm "$dest"
    fi

    clam_info "Linking $name to $dest..."
    sudo ln -s "$src" "$dest"
    
    if [[ $? -eq 0 ]]; then
        clam_success "Successfully linked '$name' as '$alias'. You can now run it directly from anywhere!"
    else
        clam_error "Failed to create symlink. You might need sudo privileges."
    fi
}

function sub_list() {
    clam_header "Managed Operational Commands"
    if [[ ! -d "$CLAM_COMMANDS_DIR" ]]; then
        echo "No commands directory found at $CLAM_COMMANDS_DIR"
        return 0
    fi

    for cmd in "${CLAM_COMMANDS_DIR}"/*(/N); do
        echo "  - ${cmd:t}"
    done
}

function sub_taste() {
    local name=$1
    if [[ -z "$name" ]]; then
        clam_error "Missing command name. Usage: clamchowder taste <name>"
        return 1
    fi

    if ! is_valid_command "$name"; then
        clam_error "Command '$name' not found."
        return 1
    fi

    # Load config and ensure variables are available for mo
    source_cmd_config "$name"
    export name="$name" 
    
    local doc_file="${CLAM_COMMANDS_DIR}/${name}/doc/explanation.mo"
    if [[ -f "$doc_file" ]]; then
        clam_header "Tasting Documentation: $name"
        # mo reads from stdin and renders using environment variables
        "$CLAM_MO" "$doc_file"
    else
        clam_error "Documentation not found for $name"
    fi
}

function sub_serve() {
    local name=$1
    shift
    if [[ -z "$name" ]]; then
        clam_error "Missing command name. Usage: clamchowder serve <name> [args]"
        return 1
    fi

    if ! is_valid_command "$name"; then
        clam_error "Command '$name' not found."
        return 1
    fi

    clam_info "Serving command: $name"
    source_cmd_config "$name"
    
    local bin_file="${CLAM_COMMANDS_DIR}/${name}/bin/main"
    if [[ -x "$bin_file" ]]; then
        "$bin_file" "$@"
    else
        clam_error "Executable not found or not runnable: $bin_file"
    fi
}

# --- Main Dispatcher ---

case "$1" in
    cook)   sub_cook "$2" ;;
    link)   sub_link "$2" ;;
    list)   sub_list ;;
    taste)  sub_taste "$2" ;;
    serve)  shift; sub_serve "$@" ;;
    help|--help|-h) usage ;;
    *)
        if [[ -n "$1" ]]; then
            clam_error "Unknown subcommand: $1"
            usage
            exit 1
        else
            usage
        fi
        ;;
esac
